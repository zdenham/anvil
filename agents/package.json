    "glob": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7",
    "vitest": "^4.0.16"
  }
}
