{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mort",
  "version": "0.0.48",
  "identifier": "com.mort.app",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 540,
        "height": 500,
        "visible": false,
        "maximizable": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "^((mailto:\\w+)|(tel:\\w+)|(https?://\\w+)|(file:///.+)).+"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../agents/package.json",
      "../agents/dist/**/*",
      "../agents/node_modules/@anthropic-ai/**/*",
      "../core/sdk/template/README.md",
      "../core/sdk/template/build.ts",
      "../core/sdk/template/package.json",
      "../core/sdk/template/tsconfig.json",
      "../core/sdk/template/mort-types/**/*",
      "../core/sdk/template/src/**/*",
      "../migrations/package.json",
      "../migrations/dist/**/*",
      "../sdk-runner.mjs",
      "../sdk-types.d.ts",
      "../plugins/mort/.claude-plugin/plugin.json",
      "../plugins/mort/skills/**/*"
    ]
  }
}
