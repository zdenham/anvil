{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mort",
  "version": "0.0.17",
  "identifier": "com.getmort.app",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Mort",
        "width": 540,
        "height": 500,
        "visible": false,
        "maximizable": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../agents/package.json",
      "../agents/dist/**/*",
      "../agents/node_modules/@anthropic-ai/**/*"
    ]
  }
}
