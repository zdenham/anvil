{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main, spotlight, clipboard, error, and control-panel windows",
  "windows": [
    "main",
    "spotlight",
    "clipboard",
    "error",
    "control-panel",
    "control-panel-window-*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-start-dragging",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "x-apple.systempreferences:*" }
      ]
    },
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "pnpm",
          "cmd": "pnpm",
          "args": true
        },
        {
          "name": "gh",
          "cmd": "gh",
          "args": true
        },
        {
          "name": "git",
          "cmd": "git",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "pnpm",
          "cmd": "pnpm",
          "args": true
        },
        {
          "name": "cargo",
          "cmd": "cargo",
          "args": true
        },
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "lsof",
          "cmd": "lsof",
          "args": true
        },
        {
          "name": "open",
          "cmd": "open",
          "args": true
        },
        {
          "name": "gh",
          "cmd": "gh",
          "args": true
        },
        {
          "name": "git",
          "cmd": "git",
          "args": true
        },
        {
          "name": "security",
          "cmd": "security",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://anvil-server.fly.dev/*" }
      ]
    }
  ]
}