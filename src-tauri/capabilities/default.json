{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main, spotlight, clipboard, task, error, simple-task, and tasks-list windows",
  "windows": [
    "main",
    "spotlight",
    "clipboard",
    "task",
    "error",
    "simple-task",
    "tasks-list"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-start-dragging",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "x-apple.systempreferences:*" }
      ]
    },
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "pnpm",
          "cmd": "pnpm",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "pnpm",
          "cmd": "pnpm",
          "args": true
        },
        {
          "name": "cargo",
          "cmd": "cargo",
          "args": true
        },
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "lsof",
          "cmd": "lsof",
          "args": true
        },
        {
          "name": "cursor",
          "cmd": "cursor",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open"
  ]
}